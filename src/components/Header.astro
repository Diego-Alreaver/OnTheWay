---
import { t, getAlternatePath, getLocalizedPath, type Lang } from "../i18n/translations";

interface Props {
  currentPath?: string;
  lang?: Lang;
}

const { currentPath = "/", lang = "es" } = Astro.props;
const tr = t(lang);
const altLang = lang === "es" ? "en" : "es";
const altPath = getAlternatePath(currentPath, lang);
const flagEmoji = lang === "es" ? "🇪🇸" : "🇺🇸";
const altFlagEmoji = lang === "es" ? "🇺🇸" : "🇪🇸";
---

<header class="fixed top-0 left-0 right-0 z-50">
  <!-- Top Bar -->
  <div class="bg-dark border-b border-gray-border">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14 md:h-16">
      <a href={getLocalizedPath("/", lang)} class="flex-shrink-0">
        <img
          src="https://onthewaylogistic.com/wp-content/uploads/2025/08/Recurso-9@2x.png"
          alt="ON THE WAY"
          class="h-6 md:h-8 w-auto object-contain"
        />
      </a>
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <a href={altPath} class="hidden sm:flex items-center gap-1.5 cursor-pointer border border-gray-border rounded px-2.5 py-1.5 hover:border-primary transition-colors">
          {lang === "es" ? (
            <svg class="w-5 h-3.5 rounded-sm" viewBox="0 0 640 480"><path fill="#c60b1e" d="M0 0h640v480H0z"/><path fill="#ffc400" d="M0 120h640v240H0z"/></svg>
          ) : (
            <svg class="w-5 h-3.5 rounded-sm" viewBox="0 0 640 480"><path fill="#012169" d="M0 0h640v480H0z"/><path fill="#FFF" d="m75 0 244 181L562 0h78v62L400 241l240 178v61h-80L320 301 82 480H0v-60l239-178L0 64V0z"/><path fill="#C8102E" d="m424 281 216 159v40L369 281zm-184 20 6 35L54 480H0zM640 0v3L391 191l2-44L590 0zM0 0l239 176h-60L0 42z"/><path fill="#FFF" d="M241 0v480h160V0zM0 160v160h640V160z"/><path fill="#C8102E" d="M0 193v96h640v-96zM273 0v480h96V0z"/></svg>
          )}
          <span class="text-xs text-white uppercase font-medium">{lang === "es" ? "ES" : "EN"}</span>
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>

        <!-- WhatsApp -->
        <a href="https://api.whatsapp.com/send?phone=17862822830" target="_blank" rel="noopener noreferrer"
          class="w-10 h-10 rounded-full bg-green-whatsapp flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="WhatsApp">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>

        <!-- Contact Button -->
        <a href="https://api.whatsapp.com/send?phone=17862822830" target="_blank" rel="noopener noreferrer"
          class="hover-pop hidden sm:block bg-green-whatsapp text-dark font-montserrat font-bold text-[15px] px-7 py-3 rounded uppercase tracking-wide">
          {tr.contactUs}
        </a>

        <!-- Mobile Menu -->
        <button id="menu-toggle" class="lg:hidden flex items-center text-white" aria-label="Menu">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Nav Bar -->
  <div class="hidden lg:block bg-dark">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-center gap-12 py-3">
      <a href={getLocalizedPath("/importaciones", lang)}
        class:list={["hover-pill-fill font-montserrat text-[15px] font-medium tracking-wider uppercase px-6 py-2.5 rounded-full border transition-colors",
          currentPath === "/importaciones" ? "border-primary text-primary" : "border-gray-light/40 text-gray-light"]}>
        {tr.importManagement}
      </a>
      <a href={getLocalizedPath("/", lang)} class="hover-float flex flex-col items-center">
        <img
          src="https://onthewaylogistic.com/wp-content/uploads/2025/08/9F8A6275-FE25-444F-B0A2-453B6EED72E2.webp"
          alt="ON THE WAY Logo"
          class="w-24 h-24 object-contain"
        />
      </a>
      <a href={getLocalizedPath("/aprende-a-importar", lang)}
        class:list={["hover-pill-fill font-montserrat text-[15px] font-medium tracking-wider uppercase px-6 py-2.5 rounded-full border transition-colors",
          currentPath === "/aprende-a-importar" ? "border-primary text-primary" : "border-gray-light/40 text-gray-light"]}>
        {tr.learnToImport}
      </a>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="lg:hidden hidden bg-dark/98 backdrop-blur-sm border-t border-gray-border">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-3">
      <a href={getLocalizedPath("/", lang)} class="font-montserrat text-sm font-medium py-2 text-white hover:text-primary">Home</a>
      <a href={getLocalizedPath("/productos-al-mayor", lang)} class="font-montserrat text-sm font-medium py-2 text-white hover:text-primary">{lang === "es" ? "Productos al mayor" : "Wholesale Products"}</a>
      <a href={getLocalizedPath("/importaciones", lang)} class="font-montserrat text-sm font-medium py-2 text-white hover:text-primary">{tr.importManagement}</a>
      <a href={getLocalizedPath("/aprende-a-importar", lang)} class="font-montserrat text-sm font-medium py-2 text-white hover:text-primary">{tr.learnToImport}</a>
      <a href="https://api.whatsapp.com/send?phone=17862822830" target="_blank" rel="noopener noreferrer" class="font-montserrat text-sm font-medium py-2 text-gold">{tr.contactUs}</a>
      <a href={altPath} class="font-montserrat text-sm font-medium py-2 text-gray-medium flex items-center gap-2">
        {altFlagEmoji} {altLang === "en" ? "English" : "Español"}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const nav = document.getElementById("mobile-nav");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  toggle?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });
</script>
