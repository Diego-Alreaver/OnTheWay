---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n/translations";

const lang = "en";
const tr = t(lang);

const categories = [
  { name: "Electronics", href: "#electronics", size: "large" },
  { name: "Clothing", href: "#clothing", size: "small" },
  { name: "Skincare", href: "#skincare", size: "small" },
  { name: "Health & Wellness", href: "#health", size: "small" },
  { name: "Makeup", href: "#makeup", size: "small" },
  { name: "Perfumes", href: "#perfumes", size: "large" },
  { name: "Handbags", href: "#handbags", size: "medium" },
];

const marqueeItems = [
  "Free shipping across the USA on orders over $1000",
  "Wholesale purchases from $397 per category",
  "Free shipping in all of Miami",
  "Trending products",
];

const products = {
  newest: [
    { name: "ON THE BOX – Mixed Handbags & Wallets (16 pieces)", price: "$393.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Korean Skincare (20 pieces)", price: "$210.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – American Skincare (70 pieces + 2 FREE)", price: "$396.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Women's Swimwear (200 pieces)", price: "", image: "/images/placeholder-product.jpg" },
  ],
  bestselling: [
    { name: "ON THE BOX – Mixed Handbags & Wallets (16 pieces)", price: "$393.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Korean Skincare (20 pieces)", price: "$210.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – American Skincare (70 pieces + 2 FREE)", price: "$396.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Women's Swimwear (200 pieces)", price: "", image: "/images/placeholder-product.jpg" },
  ],
  onSale: [
    { name: "ON THE BOX – Arabian Perfumes for Men (20 pieces)", price: "$397.00", originalPrice: "$500.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Arabian Perfumes for Women (20 pieces)", price: "$397.00", originalPrice: "$500.00", image: "/images/placeholder-product.jpg" },
    { name: "ON THE BOX – Arabian Perfumes Mix (20 pieces)", price: "$397.00", originalPrice: "$500.00", image: "/images/placeholder-product.jpg" },
  ],
};
---

<Layout title="Wholesale Products – ON THE WAY LOGISTIC">
  <Header currentPath="/productos-al-mayor" lang={lang} />
  <div class="h-[104px]"></div>

  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-dark/20 via-dark/40 to-dark z-10"></div>
    <div class="absolute inset-0 bg-gray-800"><div class="w-full h-full bg-gradient-to-br from-primary-dark/40 to-dark/80"></div></div>
    <div class="relative z-20 text-center px-4">
      <h1 class="font-montserrat font-black text-3xl md:text-5xl lg:text-6xl text-white uppercase leading-tight">{tr.shopHeroTitle}</h1>
      <a href="#newest" class="inline-block mt-8 px-8 py-3 bg-white text-dark font-montserrat font-bold text-sm rounded hover:bg-gray-100 transition-colors">{tr.shopNow}</a>
    </div>
  </section>

  <!-- Marquee -->
  <div class="bg-dark border-y border-gray-border py-3 overflow-hidden">
    <div class="marquee-track flex gap-12 text-base font-montserrat font-medium text-white whitespace-nowrap">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <span class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-primary"></span>{item}</span>
      ))}
    </div>
  </div>

  <!-- Categories -->
  <section class="py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {categories.map((cat) => (
          <a href={cat.href} class:list={["group relative rounded-2xl overflow-hidden border border-gray-border hover:border-primary/30 transition-all", cat.size === "large" ? "col-span-2 md:col-span-1 row-span-2 min-h-[280px]" : "min-h-[140px]", cat.size === "medium" ? "col-span-2 md:col-span-1 min-h-[180px]" : ""]}>
            <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-transparent z-10"></div>
            <div class="absolute inset-0 bg-primary-dark/20 group-hover:bg-primary-dark/30 transition-colors"></div>
            <div class="relative z-20 h-full flex flex-col justify-end p-4">
              <h2 class="font-montserrat font-bold text-xl md:text-2xl text-white">{cat.name}</h2>
              <span class="text-primary text-xs font-montserrat mt-1 group-hover:underline">Shop</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Search -->
  <section class="px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex gap-2 max-w-md">
        <input type="search" placeholder={tr.search} class="flex-1 bg-dark-surface border border-gray-border rounded-lg px-4 py-2 text-white text-base placeholder-gray-medium focus:border-primary focus:outline-none transition-colors" />
        <button class="bg-primary text-dark px-4 py-2 rounded-lg font-montserrat font-bold text-base hover:bg-primary/90 transition-colors">{tr.search}</button>
      </div>
    </div>
  </section>

  <!-- Newest -->
  <section class="py-12 px-4" id="newest">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-montserrat font-bold text-2xl md:text-3xl text-white">{tr.newest}</h2>
        <a href="#" class="text-primary text-sm font-montserrat hover:underline italic">{tr.seeMore}</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {products.newest.map((product) => (
          <div class="bg-dark-surface border border-gray-border rounded-xl overflow-hidden group hover:border-primary/30 transition-colors">
            <div class="aspect-square bg-white flex items-center justify-center p-4"><div class="w-full h-full bg-gray-100 rounded flex items-center justify-center text-gray-400 text-xs">Image</div></div>
            <div class="p-3">
              <h3 class="font-montserrat text-sm font-medium text-white line-clamp-2 mb-2">{product.name}</h3>
              {product.price && <p class="text-primary font-bold text-base md:text-lg">{product.price}</p>}
              <button class="mt-2 w-full bg-primary/10 text-primary border border-primary/20 rounded-lg py-1.5 text-sm font-montserrat font-medium hover:bg-primary/20 transition-colors">{product.price ? tr.addToCart : tr.readMore}</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Best Selling -->
  <section class="py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-montserrat font-bold text-2xl md:text-3xl text-white">{tr.bestSelling}</h2>
        <a href="#" class="text-primary text-sm font-montserrat hover:underline italic">{tr.seeMore}</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {products.bestselling.map((product) => (
          <div class="bg-dark-surface border border-gray-border rounded-xl overflow-hidden group hover:border-primary/30 transition-colors">
            <div class="aspect-square bg-white flex items-center justify-center p-4"><div class="w-full h-full bg-gray-100 rounded flex items-center justify-center text-gray-400 text-xs">Image</div></div>
            <div class="p-3">
              <h3 class="font-montserrat text-sm font-medium text-white line-clamp-2 mb-2">{product.name}</h3>
              {product.price && <p class="text-primary font-bold text-base md:text-lg">{product.price}</p>}
              <button class="mt-2 w-full bg-primary/10 text-primary border border-primary/20 rounded-lg py-1.5 text-sm font-montserrat font-medium hover:bg-primary/20 transition-colors">{product.price ? tr.addToCart : tr.readMore}</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- On Sale -->
  <section class="py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-montserrat font-bold text-2xl md:text-3xl text-white">{tr.onSale}</h2>
        <a href="#" class="text-primary text-sm font-montserrat hover:underline italic">{tr.seeMore}</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {products.onSale.map((product) => (
          <div class="bg-dark-surface border border-gray-border rounded-xl overflow-hidden group hover:border-primary/30 transition-colors relative">
            <span class="absolute top-2 left-2 z-10 bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded">{tr.sale}</span>
            <div class="aspect-square bg-white flex items-center justify-center p-4"><div class="w-full h-full bg-gray-100 rounded flex items-center justify-center text-gray-400 text-xs">Image</div></div>
            <div class="p-3">
              <h3 class="font-montserrat text-sm font-medium text-white line-clamp-2 mb-2">{product.name}</h3>
              <div class="flex items-center gap-2">
                {product.originalPrice && <span class="text-gray-medium line-through text-xs">{product.originalPrice}</span>}
                <span class="text-primary font-bold text-base md:text-lg">{product.price}</span>
              </div>
              <button class="mt-2 w-full bg-primary/10 text-primary border border-primary/20 rounded-lg py-1.5 text-sm font-montserrat font-medium hover:bg-primary/20 transition-colors">{tr.addToCart}</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>

<style>
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .marquee-track { animation: marquee 20s linear infinite; }
</style>
