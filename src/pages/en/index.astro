---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n/translations";

const lang = "en";
const tr = t(lang);

const reviews = [
  { name: "Laura Estefania Marin Paiva", text: "I'm Laura, based in Barcelona, Anzoátegui. I run an online store for makeup, accessories, and fragrances. Over two years ago, I took the leap and invested with a team I had to trust. Today, I can say it was the best decision I've ever made. ON THE WAY has been fundamental in growing my business..." },
  { name: "Gabriel De Garate", text: "Responsible and professional!! 100% recommended" },
  { name: "Laura Rivas", text: "It's incredible to see them grow, their commitment goes beyond delivering a package. I noticed the dedication to providing fast and safe solutions. They're always by our side, always on the way❤️" },
  { name: "Jesus Hernandez", text: "Always ready to provide solutions. The service is first-hand and their logistics work perfectly." },
  { name: "Josnelxis Herrrera", text: "Excellent service, great repacking, excellent content, I define them as The Best" },
  { name: "mariand figueroa", text: "When people ask me which company to ship with? Without a doubt I recommend On The Way. I've been shipping with them for over 2 years and they are 1000/10, super responsible, reliable, fast, safe..." },
  { name: "Valeria Chacin", text: "Excellent company for your shipments or if you're looking to start a business, they're super attentive at all times..." },
  { name: "Frande Blanco", text: "Excellent shipping agency, packages arrive super fast and safely. 100% recommended" },
  { name: "Alejandra Rondon", text: "I've had my mailbox at On The Way for about 6 months and I've been delighted with their personalized attention..." },
  { name: "RIcardo Delgado", text: "They provide quality service, always willing to answer questions, give suggestions and guide you..." },
];
---

<Layout title="ON THE WAY LOGISTIC">
  <Header currentPath="/" lang={lang} />
  <div class="h-[104px] lg:h-[104px]"></div>

  <!-- Hero Section with Video -->
  <section class="relative h-[50vh] md:h-[60vh] flex items-center justify-center overflow-hidden">
    <video class="absolute inset-0 w-full h-full object-cover hidden md:block" autoplay muted loop playsinline>
      <source src="https://onthewaylogistic.com/wp-content/uploads/2026/03/FINAL-4K-HORIZONTAL-V2.mp4" type="video/mp4" />
    </video>
    <video class="absolute inset-0 w-full h-full object-cover md:hidden" autoplay muted loop playsinline>
      <source src="https://onthewaylogistic.com/wp-content/uploads/2026/03/VERTICAL-4K-V1.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-dark/40"></div>
    <div class="relative z-10 flex flex-col items-center">
      <img
        src="https://onthewaylogistic.com/wp-content/uploads/2025/08/9F8A6275-FE25-444F-B0A2-453B6EED72E2.webp"
        alt="ON THE WAY Logo"
        class="w-32 h-32 md:w-40 md:h-40 object-contain mb-4"
      />
      <h1 class="font-montserrat font-bold text-4xl md:text-6xl lg:text-7xl text-white tracking-[0.2em] uppercase">ON THE WAY</h1>
    </div>
  </section>

  <!-- Welcome -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h2 class="font-montserrat font-bold text-3xl md:text-5xl text-primary mb-6">{tr.welcomeTitle}</h2>
      <p class="text-gray-light text-base md:text-lg leading-relaxed max-w-3xl mx-auto">{tr.welcomeText}</p>
    </div>
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div class="bg-dark-surface border border-gray-border rounded-2xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <img
          src="https://onthewaylogistic.com/wp-content/uploads/2025/09/MapChart_Map-2-1-scaled.png"
          alt="World map"
          class="w-full h-auto rounded-lg mb-4"
          loading="lazy"
        />
        <p class="text-primary text-base font-montserrat">{tr.connectMarkets}</p>
      </div>
      <div class="bg-dark-surface border border-gray-border rounded-2xl p-8">
        <h3 class="font-montserrat font-bold text-2xl md:text-3xl text-primary mb-6">{tr.whyChooseUs}</h3>
        <ul class="space-y-4">
          {tr.whyItems.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-green-400 font-bold text-sm">✓</span>
              <p class="text-gray-light text-base leading-relaxed">
                <span class="font-semibold text-primary underline">{item.title}</span>{" "}{item.desc}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-8 px-4">
    <div class="max-w-3xl mx-auto border border-gold/40 rounded-2xl p-8 text-center bg-dark-surface">
      <p class="text-gray-light text-lg md:text-xl mb-2">{tr.ctaQuestion}</p>
      <p class="font-montserrat font-bold text-red-500 text-xl md:text-2xl">{tr.ctaAction}</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 relative overflow-hidden" style="background: linear-gradient(180deg, #000 0%, #0060C0 50%, #0060C0 70%, #000 100%);">
    <div class="max-w-7xl mx-auto px-4">
      <div class="relative">
        <div class="overflow-hidden" id="services-viewport">
          <div class="flex gap-4 transition-transform duration-500 ease-in-out" id="services-track">
            {tr.services.map((service) => (
              <div class="flex-shrink-0 w-[280px] md:w-[300px] bg-dark-surface/70 backdrop-blur border border-primary/20 rounded-2xl p-6 flex flex-col min-h-[350px]">
                <h2 class="font-montserrat font-bold text-xl md:text-2xl text-white mb-2 text-center">{service.title}</h2>
                {service.subtitle && <p class="text-gray-light text-sm md:text-base text-center mb-4 leading-relaxed">{service.subtitle}</p>}
                {service.items.length > 0 && (
                  <ul class="space-y-2 text-center">
                    {service.items.map((item) => <li class="text-gray-light text-sm md:text-base">{item}</li>)}
                  </ul>
                )}
                <div class="mt-auto pt-6 flex justify-center">
                  <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center">
                    <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="flex justify-center gap-4 mt-8">
          <button id="services-prev" class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors" aria-label="Previous">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button id="services-next" class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors" aria-label="Next">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="overflow-hidden relative">
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" id="reviews-track">
          {reviews.map((review) => (
            <div class="flex-shrink-0 w-[280px] snap-start bg-dark-surface border border-gray-border rounded-xl p-5">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-sm">{review.name.charAt(0)}</div>
                  <span class="font-montserrat font-medium text-xs text-white">{review.name}</span>
                </div>
                <svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
              </div>
              <div class="flex gap-0.5 mb-3">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <p class="text-gray-light text-xs leading-relaxed line-clamp-6">{review.text}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center gap-4 mt-6">
        <button id="reviews-prev" class="w-10 h-10 rounded-full border border-gray-border flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors" aria-label="Previous">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="reviews-next" class="w-10 h-10 rounded-full border border-gray-border flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors" aria-label="Next">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const reviewsTrack = document.getElementById("reviews-track");
  document.getElementById("reviews-prev")?.addEventListener("click", () => { reviewsTrack?.scrollBy({ left: -300, behavior: "smooth" }); });
  document.getElementById("reviews-next")?.addEventListener("click", () => { reviewsTrack?.scrollBy({ left: 300, behavior: "smooth" }); });

  const servicesTrack = document.getElementById("services-track");
  const servicesViewport = document.getElementById("services-viewport");
  let servicesOffset = 0;
  document.getElementById("services-prev")?.addEventListener("click", () => {
    servicesOffset = Math.max(servicesOffset - 320, 0);
    if (servicesTrack) servicesTrack.style.transform = `translateX(-${servicesOffset}px)`;
  });
  document.getElementById("services-next")?.addEventListener("click", () => {
    const maxOffset = servicesTrack ? servicesTrack.scrollWidth - (servicesViewport?.clientWidth || 0) : 0;
    servicesOffset = Math.min(servicesOffset + 320, maxOffset);
    if (servicesTrack) servicesTrack.style.transform = `translateX(-${servicesOffset}px)`;
  });
</script>
