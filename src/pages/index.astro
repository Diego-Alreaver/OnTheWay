---

<Layout title="ON THE WAY LOGISTIC">
  <Header currentPath="/" lang="es" />

  <!-- Spacer for fixed header (2 bars) -->
  <div class="h-[56px] lg:h-[160px]"></div>

  <!-- Hero Section with Video -->
  <section class="relative h-[50vh] md:h-[60vh] flex items-center justify-center overflow-hidden">
    <!-- Desktop Video -->
    <video class="absolute inset-0 w-full h-full object-cover hidden md:block" autoplay muted loop playsinline>
      <source src="https://onthewaylogistic.com/wp-content/uploads/2026/03/FINAL-4K-HORIZONTAL-V2.mp4" type="video/mp4" />
    </video>
    <!-- Mobile Video -->
    <video class="absolute inset-0 w-full h-full object-cover md:hidden" autoplay muted loop playsinline>
      <source src="https://onthewaylogistic.com/wp-content/uploads/2026/03/VERTICAL-4K-V1.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-dark/30"></div>
  </section>

  <!-- Welcome Section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h2 class="animate-on-scroll font-montserrat font-bold text-[2rem] md:text-[3.2rem] leading-tight text-primary-light mb-6">
        Welcome to OnTheWayLogistic.com
      </h2>
      <p class="animate-on-scroll stagger-1 text-[#E0E0E0] text-[1.05rem] md:text-[1.15rem] leading-[1.8] max-w-3xl mx-auto">
        Experiencia en el mercado internacional desde hace más de 7 años, ON THE WAY LOGISTIC INC se ha consolidado como el aliado estratégico de empresarios y emprendedores en Latinoamérica que buscan crecer con proveedores confiables en China y Estados Unidos. Nuestra misión es simplificar todo el proceso logístico y ayudarte a obtener las mejores oportunidades para tu negocio.
      </p>
    </div>

    <!-- Why Choose Us -->
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <!-- Map Image -->
      <div class="animate-on-scroll scale-in hover-lift hover-glow border-2 border-primary-light/20 rounded-[20px] p-8 flex flex-col items-center justify-center min-h-[300px]">
        <img
          src="https://onthewaylogistic.com/wp-content/uploads/2025/09/MapChart_Map-2-1-scaled.png"
          alt="Mapa mundial"
          class="w-full h-auto rounded-lg mb-4"
          loading="lazy"
        />
        <p class="text-primary-light text-base font-montserrat">Conectamos mercados globalmente</p>
      </div>

      <!-- Why Choose Us List -->
      <div class="animate-on-scroll stagger-2 scale-in hover-lift hover-glow border border-white/10 rounded-[25px] p-10 shadow-[0_10px_30px_rgba(0,0,0,0.2)]">
        <h3 class="font-montserrat font-bold text-[1.6rem] md:text-[2rem] text-primary-light mb-6">
          ¿Por qué elegirnos?
        </h3>
        <ul class="space-y-5">
          {whyChooseUs.map((item) => (
            <li class="hover-bounce flex items-start gap-3">
              <span class="mt-1 flex-shrink-0">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="12" fill="#4FACFE"/>
                  <path d="M7 12.5l3 3 7-7" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <p class="text-gray-light text-base leading-relaxed">
                <span class="hover-underline font-semibold text-primary-light">{item.title}</span>{" "}
                {item.desc}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-8 px-4">
    <div class="animate-on-scroll scale-in max-w-3xl mx-auto border-2 border-primary-light/20 rounded-[30px] py-12 px-10 text-center shadow-[0_15px_40px_rgba(79,172,254,0.15)] backdrop-blur-[20px]" style="background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(79,172,254,0.05));">
      <p class="text-[#D0D0D0] text-[1.15rem] md:text-[1.4rem] mb-3">
        ¿Quieres llevar tu negocio al siguiente nivel con un socio logístico de confianza?
      </p>
      <p class="font-montserrat font-bold text-gold text-[1.35rem] md:text-[1.6rem]">
        Empieza a invertir hoy mismo y crece con confianza!
      </p>
    </div>
  </section>

  <!-- Services Section (Blue gradient bg) -->
  <section class="py-16 relative" style="background: linear-gradient(180deg, #000 0%, #0060C0 50%, #0060C0 70%, #000 100%);">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {services.map((service) => (
          <div class="hover-lift hover-glow bg-dark-surface/70 backdrop-blur border border-primary/20 rounded-2xl p-6 flex flex-col min-h-[350px]">
            <h2 class="font-montserrat font-normal text-[1.4rem] md:text-[1.8rem] text-white mb-2 text-center leading-tight">
              {service.title}
            </h2>
            {service.subtitle && (
              <p class="text-gray-light text-[0.95rem] md:text-[1.05rem] text-center mb-4 leading-relaxed">{service.subtitle}</p>
            )}
            {service.items.length > 0 && (
              <ul class="space-y-2 text-center">
                {service.items.map((item) => (
                  <li class="text-gray-light text-[0.95rem] md:text-[1.05rem]">{item}</li>
                ))}
              </ul>
            )}
            <div class="mt-auto pt-6 flex justify-center">
              <img src={service.image} alt={service.title} class="hover-float w-28 h-28 object-contain" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Reviews Section -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="overflow-hidden relative" id="reviews-container">
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" id="reviews-track">
          {reviews.map((review) => (
            <div class="hover-lift hover-glow flex-shrink-0 w-[280px] snap-start bg-dark-surface border border-gray-border rounded-xl p-5">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-sm">
                    {review.name.charAt(0)}
                  </div>
                  <span class="font-montserrat font-medium text-xs text-white">{review.name}</span>
                </div>
                <!-- Google G icon -->
                <svg class="w-5 h-5 text-gray-medium" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <div class="flex gap-0.5 mb-3">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-gray-light text-xs leading-relaxed line-clamp-6">{review.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Carousel Controls -->
      <div class="flex justify-center gap-4 mt-6">
        <button
          id="reviews-prev"
          class="w-10 h-10 rounded-full border border-gray-border flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors"
          aria-label="Anterior"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="reviews-next"
          class="w-10 h-10 rounded-full border border-gray-border flex items-center justify-center text-white hover:border-primary hover:text-primary transition-colors"
          aria-label="Siguiente"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <Footer lang="es" />
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  // Reviews carousel
  const reviewsTrack = document.getElementById("reviews-track");
  document.getElementById("reviews-prev")?.addEventListener("click", () => {
    reviewsTrack?.scrollBy({ left: -300, behavior: "smooth" });
  });
  document.getElementById("reviews-next")?.addEventListener("click", () => {
    reviewsTrack?.scrollBy({ left: 300, behavior: "smooth" });
  });

  // Services carousel
  const servicesTrack = document.getElementById("services-track");
  const servicesViewport = document.getElementById("services-viewport");
  let servicesOffset = 0;

  document.getElementById("services-prev")?.addEventListener("click", () => {
    servicesOffset = Math.max(servicesOffset - 320, 0);
    if (servicesTrack) servicesTrack.style.transform = `translateX(-${servicesOffset}px)`;
  });
  document.getElementById("services-next")?.addEventListener("click", () => {
    const maxOffset = servicesTrack ? servicesTrack.scrollWidth - (servicesViewport?.clientWidth || 0) : 0;
    servicesOffset = Math.min(servicesOffset + 320, maxOffset);
    if (servicesTrack) servicesTrack.style.transform = `translateX(-${servicesOffset}px)`;
  });
</script>
