---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const reviews = [
  {
    name: "Laura Estefania Marin Paiva",
    text: "Hola soy Laura y resido en Barcelona, Edo. Anzoátegui, dirijo una tienda online de maquillaje, accesorios y fragancias. Hace más de dos años, decidí dar el primer paso y arriesgarme a invertir con un equipo en el que debía confiar. Hoy, puedo afirmar que ha sido la mejor decisión que he tomado. ON THE WAY ha sido un pilar fundamental en el crecimiento de mi emprendimiento, y con cada caja que recibo, confirmo que su excelente servicio, guía y recomendaciones convierten cada inversión en un acierto total.",
  },
  {
    name: "Gabriel De Garate",
    text: "Responsables y profesionales!! Recomendados 100%",
  },
  {
    name: "Laura Rivas",
    text: "Es increíble verlos crecer, su compromiso va más allá de entregar un paquete. Note la dedicación para brindar soluciones rápidas y seguras. Siempre están a nuestro lado, siempre están en camino❤️",
  },
  {
    name: "Jesus Hernandez",
    text: "Siempre presto en darte soluciones. La atención es de primera mano y su logística funciona a la perfección.",
  },
  {
    name: "Josnelxis Herrrera",
    text: "Excelente atención, buen reempaque, excelente su contenido, los defino como Los Mejores",
  },
  {
    name: "mariand figueroa",
    text: "Cuando me preguntan con qué empresa puedo enviar? Sin duda les recomiendo On The Way tengo más de 2 años enviando con ellos y son un 1000/10 súper responsables, confiables, rápidos, seguro, mi mercancía siempre ha llegado excelente y son de verdad muy eficientes, siempre tienen una respuesta a tus dudas, siempre atentos a cualquier requerimiento, para mí sus servicios son los mejores en lo que hacen. 100% recomendados.",
  },
  {
    name: "Valeria Chacin",
    text: "Excelente compañía para hacer tus envíos o si buscas emprender, son súper atentos en todo momento, siempre que tengo alguna duda con respecto a los envíos o estoy en búsqueda de información, están dispuestos a responder cualquier duda y con mucha amabilidad!",
  },
  {
    name: "Frande Blanco",
    text: "Excelente agencia de envíos, sus envíos llegan súper rápido y seguro 100% recomendado",
  },
  {
    name: "Alejandra Rondon",
    text: "Tengo mi casillero en on the way hace aproximadamente 6 meses y las veces que lo he utilizado para mis compras de SheIn y Temu he quedado encantada con su atención, es súper personalizada, siempre responden y están atentos a nuestros paquetes, lo mejor, llega hasta puerto la cruz, se retira sin colas ni mucho protocolo. Excelente y recomendados.",
  },
  {
    name: "RIcardo Delgado",
    text: "Prestan un servicio de calidad, siempre dispuestos a aclarar dudas, dar sugerencias y guiarte en los servicios que ofrecen, son mi empresa de envíos de confianza siempre los recomiendo 100%.",
  },
];

const whyChooseUs = [
  { title: "Soluciones Integrales:", desc: "Desde la compra hasta la entrega, cubrimos cada etapa del proceso." },
  { title: "Tiempos de Entrega Optimizados:", desc: "Diseñamos rutas eficientes para que recibas tu carga a tiempo." },
  { title: "Comunicación Transparente:", desc: "Te mantenemos informado en cada paso de la operación." },
  { title: "Asesoría Personalizada:", desc: "Recibe acompañamiento de expertos en importación y gestión de compras." },
  { title: "Confianza y Experiencia:", desc: "Más de 1,000 emprendedores y empresarios han trabajado con nosotros." },
];

const WP = "https://onthewaylogistic.com/wp-content/uploads/2025/08";
const services = [
  {
    title: "Asesoría Personalizada",
    subtitle: "Acompañamiento en todo el proceso logístico de tu caja",
    items: [],
    image: `${WP}/svgviewer-png-output-1.png`,
  },
  {
    title: "Envíos Internacionales",
    subtitle: "Desde USA hacia países como Venezuela, República Dominicana, Perú, Chile, México, Canadá, Ecuador, Colombia, Nicaragua, España.",
    items: [],
    image: `${WP}/Recurso-6.png`,
  },
  {
    title: "Envíos Nacionales dentro de USA",
    subtitle: "",
    items: ["-Alianzas con UPS.", "-Tarifas exclusivas para clientes.", "-Entregas puerta a puerta con seguimiento."],
    image: `${WP}/Recurso-6-1.png`,
  },
  {
    title: "Gestión en China",
    subtitle: "(Broker / Acompañamiento de Importación)",
    items: ["-Auditoría y verificación de fábricas.", "-Control de calidad y tiempos de entrega.", "-Administración segura de pagos."],
    image: `${WP}/Recurso-7.png`,
  },
