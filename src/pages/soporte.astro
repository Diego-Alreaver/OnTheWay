---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLocalizedPath } from "../i18n/translations";

const lang = "es";

const policies = [
  {
    title: "Politica de Privacidad",
    desc: "Conoce como recopilamos, usamos y protegemos tu informacion personal.",
    href: getLocalizedPath("/politica-de-privacidad", lang),
    icon: "shield",
  },
  {
    title: "Politica de Devoluciones y Reembolsos",
    desc: "Informate sobre nuestras condiciones de devolucion y reembolso de servicios.",
    href: getLocalizedPath("/politica-de-devoluciones-y-reembolsos", lang),
    icon: "refresh",
  },
  {
    title: "Terminos y Condiciones de Servicio",
    desc: "Revisa los terminos bajo los cuales operamos y prestamos nuestros servicios.",
    href: getLocalizedPath("/terminos-y-condiciones-de-servicio", lang),
    icon: "document",
  },
  {
    title: "Aviso Legal",
    desc: "Consulta la informacion legal sobre nuestra empresa y jurisdiccion aplicable.",
    href: getLocalizedPath("/aviso-legal", lang),
    icon: "scale",
  },
];
---

<Layout title="Soporte - ON THE WAY LOGISTIC">
  <Header currentPath="/soporte" lang={lang} />

  <!-- Spacer for fixed header -->
  <div class="h-[56px] lg:h-[160px]"></div>

  <!-- Hero Banner -->
  <section class="py-16 px-4" style="background: linear-gradient(135deg, #0060C0 0%, #0040A0 100%);">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-montserrat font-bold text-3xl md:text-5xl text-white mb-2 tracking-wide">
        ON THE WAY LOGISTIC INC
      </h1>
      <p class="font-montserrat text-lg md:text-xl text-white/80 mb-8">
        Servicios Logisticos Internacionales
      </p>
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/20">
        <h2 class="font-montserrat font-bold text-xl md:text-2xl text-white mb-4">
          Politicas de Privacidad, Devoluciones y Terminos de Servicio
        </h2>
        <p class="text-white/90 text-sm md:text-base leading-relaxed">
          Bienvenido a ON THE WAY LOGISTIC INC. Al utilizar nuestros servicios, confirmas que has leido, entendido y aceptado estas politicas.
        </p>
      </div>
    </div>
  </section>

  <!-- Policy Cards -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {policies.map((policy) => (
        <a href={policy.href} class="bg-dark-surface border border-gray-border rounded-2xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/30 transition-colors">
              {policy.icon === "shield" && (
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {policy.icon === "refresh" && (
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              )}
              {policy.icon === "document" && (
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {policy.icon === "scale" && (
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-montserrat font-bold text-lg text-primary mb-2 group-hover:text-primary transition-colors">
                {policy.title}
              </h3>
              <p class="text-gray-light text-sm leading-relaxed">
                {policy.desc}
              </p>
            </div>
          </div>
          <div class="mt-4 flex justify-end">
            <span class="text-primary text-sm font-montserrat font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              Leer mas
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-12 px-4 border-t border-gray-border">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-montserrat font-bold text-xl text-primary mb-2">ON THE WAY LOGISTIC INC</h2>
      <p class="text-gray-light text-sm mb-4">Miami, Florida - Estados Unidos</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="mailto:info@onthewaylogistic.com" class="text-primary text-sm hover:underline">info@onthewaylogistic.com</a>
        <span class="hidden sm:inline text-gray-border">|</span>
        <a href="mailto:support@onthewaylogistic.com" class="text-primary text-sm hover:underline">support@onthewaylogistic.com</a>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
